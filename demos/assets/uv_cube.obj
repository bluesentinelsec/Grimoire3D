# uv_cube.obj — synthetic test asset for Grimoire3D Phase 3
# Unit cube, 6 faces (quads), each face UV-mapped to a distinct checker quadrant.
mtllib uv_cube.mtl
o uv_cube

v -0.5000 -0.5000 -0.5000
v 0.5000 -0.5000 -0.5000
v 0.5000 0.5000 -0.5000
v -0.5000 0.5000 -0.5000
v -0.5000 -0.5000 0.5000
v 0.5000 -0.5000 0.5000
v 0.5000 0.5000 0.5000
v -0.5000 0.5000 0.5000

vt 0.000000 0.000000
vt 0.250000 0.000000
vt 0.250000 0.500000
vt 0.000000 0.500000
vt 0.250000 0.000000
vt 0.500000 0.000000
vt 0.500000 0.500000
vt 0.250000 0.500000
vt 0.500000 0.000000
vt 0.750000 0.000000
vt 0.750000 0.500000
vt 0.500000 0.500000
vt 0.750000 0.000000
vt 1.000000 0.000000
vt 1.000000 0.500000
vt 0.750000 0.500000
vt 0.000000 -0.500000
vt 0.250000 -0.500000
vt 0.250000 0.000000
vt 0.000000 0.000000
vt 0.250000 -0.500000
vt 0.500000 -0.500000
vt 0.500000 0.000000
vt 0.250000 0.000000

vn 1.0000 0.0000 0.0000
vn -1.0000 0.0000 0.0000
vn 0.0000 1.0000 0.0000
vn 0.0000 -1.0000 0.0000
vn 0.0000 0.0000 1.0000
vn 0.0000 0.0000 -1.0000

usemtl checker
s off

f 2/1/1 6/2/1 7/3/1 3/4/1
f 5/5/2 1/6/2 4/7/2 8/8/2
f 4/9/3 3/10/3 7/11/3 8/12/3
f 5/13/4 6/14/4 2/15/4 1/16/4
f 6/17/5 5/18/5 8/19/5 7/20/5
f 1/21/6 2/22/6 3/23/6 4/24/6
